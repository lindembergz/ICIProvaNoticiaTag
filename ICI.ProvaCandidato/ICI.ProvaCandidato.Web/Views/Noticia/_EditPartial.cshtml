@model ICiProvaCandidato.Web.Models.NoticiaViewModel


<form id="formNoticia">
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label">Título</label>
        <input asp-for="Titulo" class="form-control" required maxlength="200" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Conteudo" class="form-label">Conteúdo</label>
        <textarea asp-for="Conteudo" class="form-control" rows="6" required>@Model.Conteudo</textarea>
        <span asp-validation-for="Conteudo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Tags</label>
        <div class="row">
            @foreach (var tag in ViewBag.Tags as IEnumerable<ICiProvaCandidato.Aplicacao.DTOs.TagDto>)
            {
                <div class="col-md-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               name="TagIdsSelecionadas" value="@tag.Id" id="tag_@tag.Id"
                        @(Model.TagIdsSelecionadas.Contains(tag.Id) ? "checked" : "") />
                        <label class="form-check-label" for="tag_@tag.Id">
                            @tag.Nome
                        </label>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">
            Cancelar
        </button>
        <button type="submit" class="btn btn-primary">
            Atualizar
        </button>
    </div>
</form>