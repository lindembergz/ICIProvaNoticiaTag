@model IEnumerable<ICiProvaCandidato.Web.Models.TagViewModel>

@{
    ViewData["Title"] = "Tags";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>@ViewData["Title"]</h2>
                <button type="button" class="btn btn-primary" id="btnNovaTag">
                    <i class="fas fa-plus"></i> Nova Tag
                </button>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    Nenhuma tag cadastrada.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var tag in Model)
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">@tag.Nome</h5>
                                    <p class="card-text">
                                        @Html.Raw(string.IsNullOrEmpty(tag.Descricao) ? "Sem descrição" :
                                                 tag.Descricao.Length > 100 ? tag.Descricao.Substring(0, 100) + "..." : tag.Descricao)
                                    </p>
                                    <small class="text-muted">
                                        Status: @(tag.Ativa == true ? "Ativa" : "Inativa")
                                    </small>
                                </div>
                                <div class="card-footer bg-transparent">
                                    <div class="btn-group w-100">
                                        <button type="button" class="btn btn-outline-primary btn-editar"
                                                data-id="@tag.Id">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
                                        <button type="button" class="btn btn-outline-danger btn-excluir" data-id="@tag.Id">
                                            <i class="fas fa-trash"></i> Excluir
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal para formulários -->
<div class="modal fade" id="modalFormulario" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tag</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Conteúdo carregado via Ajax -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/additional-methods.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/tag.js"></script>
}