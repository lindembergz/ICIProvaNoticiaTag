@model ICiProvaCandidato.Web.Models.TagViewModel
<form id="formTag">
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" id="Nome" name="Nome" required maxlength="50" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Descricao" class="form-label">Descrição</label>
        <textarea asp-for="Descricao" class="form-control" id="Descricao" name="Descricao" rows="3" maxlength="200">@Model.Descricao</textarea>
        <span asp-validation-for="Descricao" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <input asp-for="Ativa" class="form-check-input" type="checkbox" id="Ativa" />
            <label class="form-check-label" for="Ativa">
                Ativa
            </label>
        </div>
        <span asp-validation-for="Ativa" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">
            Cancelar
        </button>
        <button type="submit" class="btn btn-primary">
            Atualizar
        </button>
    </div>
</form>